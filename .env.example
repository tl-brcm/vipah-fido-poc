# ── VIP Auth Hub Server ──────────────────────────────────────────────────────
# Base URL of the VIP Auth Hub tenant endpoint
VIPAH_BASE_URL=https://ssp-215.demo-broadcom.com/default

# ── Privileged Client Credentials ────────────────────────────────────────────
# OAuth2 client_credentials used to obtain an access token for all API calls.
# Create/find these under: Tenant Admin → Applications → your privileged client.
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# ── Test User ─────────────────────────────────────────────────────────────────
# The VIP Auth Hub user to register / authenticate FIDO for.
# The user must exist and the password must be correct.
TEST_USERNAME=your-test-username
TEST_PASSWORD=your-test-password
# Internal VIP Auth Hub user ID (UUID).  Run GET /admin/v1/Users?filter=user_loginid eq <username>
# to look this up, then paste the "userId" field here.
TEST_USER_ID=your-user-uuid-here

# ── FIDO / WebAuthn ───────────────────────────────────────────────────────────
# The Relying Party domain sent to VIP Auth Hub as "documentDomain".
# Must be a registrable domain suffix of the browser origin, e.g.:
#   browser at https://fido-test.demo-broadcom.com:3000  →  RP_DOMAIN=demo-broadcom.com
# VIP Auth Hub stores the credential under this domain and uses it to route
# the FIDO_AUTH_GENERATE_CHALLENGE flow on subsequent logins.
RP_DOMAIN=demo-broadcom.com

# ── Flask Server ──────────────────────────────────────────────────────────────
FLASK_PORT=3000
# Paths to TLS certificate and key (relative to project root or absolute).
# Generate with: mkcert fido-test.demo-broadcom.com localhost 127.0.0.1
TLS_CERT=certs/cert.pem
TLS_KEY=certs/key.pem

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log file path. Leave empty to log to console only.
LOG_FILE=
# Set to true to include full request/response payloads in DEBUG logs.
LOG_PAYLOADS=false
